---
interface Props {
  variant?: 'primary' | 'accent' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button'
} = Astro.props;

const baseStyles = 'font-medium rounded transition-colors duration-200 inline-flex items-center justify-center whitespace-nowrap';

const variants = {
  primary: 'bg-primary text-white hover:bg-primary-dark',
  accent: 'bg-accent text-white hover:bg-accent',
  secondary: 'border border-primary text-primary bg-white hover:bg-accent-soft'
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base min-h-[44px]',
  lg: 'px-8 py-4 text-lg min-h-[48px]'
};

const className = `${baseStyles} ${variants[variant]} ${sizes[size]}`;

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={className}>
    <slot />
  </a>
) : (
  <button type={type} class={className}>
    <slot />
  </button>
)}
