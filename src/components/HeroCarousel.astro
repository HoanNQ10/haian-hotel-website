---
const slides = [
  { image: '/images/hero/hero-01.jpg', alt: 'Hải An Villa Hotel' },
  { image: '/images/hero/hero-02.jpg', alt: 'Hải An Villa Hotel' },
  { image: '/images/hero/hero-03.jpg', alt: 'Hải An Villa Hotel' },
];
---

<div id="hero-outer" class="relative w-full overflow-hidden h-[80vh]">

  {slides.map((slide, index) => (
    <div
      class="absolute overflow-hidden"
      data-slide={index}
      style="left:0;top:0;width:100%;height:100%;opacity:0;z-index:1;"
    >
      <img
        src={slide.image}
        alt={slide.alt}
        class="absolute inset-0 w-full h-full object-cover"
      />
    </div>
  ))}

  <!-- Dark gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/20 to-transparent pointer-events-none z-10"
    aria-hidden="true"
  ></div>

  <!-- Prev -->
  <button
    id="carousel-prev"
    class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 bg-white/15 hover:bg-white/30 backdrop-blur-sm text-white p-3 md:p-4 rounded-full transition-all duration-200 hover:scale-110 active:scale-95 border border-white/20 hover:border-white/40"
    aria-label="Previous slide"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <!-- Next -->
  <button
    id="carousel-next"
    class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 bg-white/15 hover:bg-white/30 backdrop-blur-sm text-white p-3 md:p-4 rounded-full transition-all duration-200 hover:scale-110 active:scale-95 border border-white/20 hover:border-white/40"
    aria-label="Next slide"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Dots -->
  <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-2 z-20">
    {slides.map((_, index) => (
      <button
        data-dot={index}
        class="h-1.5 rounded-full transition-all duration-300"
        aria-label={`Slide ${index + 1}`}
      ></button>
    ))}
  </div>

</div>

<script>
  const outer    = document.getElementById('hero-outer') as HTMLElement;
  const slideEls = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
  const dotEls   = Array.from(document.querySelectorAll<HTMLElement>('[data-dot]'));
  const prevBtn  = document.getElementById('carousel-prev');
  const nextBtn  = document.getElementById('carousel-next');

  const TOTAL      = slideEls.length;
  const SIDE_RATIO = 0.18; // each side peek = 18% of container width
  const TRANS      = 'left 700ms ease-in-out, width 700ms ease-in-out, height 700ms ease-in-out, top 700ms ease-in-out, opacity 700ms ease-in-out';

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function applyLayout(animated: boolean) {
    const W     = outer.offsetWidth;
    const isMob = window.innerWidth < 768;
    const sideW = isMob ? 0 : Math.round(W * SIDE_RATIO);
    const mainW = W - sideW * 2;

    slideEls.forEach((el, i) => {
      el.style.transition = animated ? TRANS : 'none';
      const off = ((i - current) + TOTAL) % TOTAL;

      if (isMob) {
        // Mobile: simple crossfade, single full-width slide
        Object.assign(el.style, {
          left: '0', top: '0', width: '100%', height: '100%',
          opacity: off === 0 ? '1' : '0',
          zIndex:  off === 0 ? '8' : '1',
        });
      } else if (off === 0) {
        // Center — active, full height
        Object.assign(el.style, {
          left: sideW + 'px', top: '0',
          width: mainW + 'px', height: '100%',
          opacity: '1', zIndex: '8',
        });
      } else if (off === 1) {
        // Right peek — narrower, vertically inset
        Object.assign(el.style, {
          left: (sideW + mainW) + 'px', top: '5%',
          width: sideW + 'px', height: '90%',
          opacity: '0.6', zIndex: '5',
        });
      } else if (off === TOTAL - 1) {
        // Left peek — narrower, vertically inset
        Object.assign(el.style, {
          left: '0', top: '5%',
          width: sideW + 'px', height: '90%',
          opacity: '0.6', zIndex: '5',
        });
      } else {
        // Hidden — parked off-screen in the direction they'll enter from
        const enterFromRight = off < Math.ceil(TOTAL / 2);
        Object.assign(el.style, {
          left: enterFromRight ? (W + sideW) + 'px' : (-sideW * 2) + 'px', top: '5%',
          width: sideW + 'px', height: '90%',
          opacity: '0', zIndex: '1',
        });
      }
    });

    dotEls.forEach((d, i) => {
      d.className = i === current
        ? 'h-1.5 rounded-full transition-all duration-300 w-8 bg-white'
        : 'h-1.5 rounded-full transition-all duration-300 w-4 bg-white/50 hover:bg-white/80';
    });
  }

  function goTo(idx: number) {
    current = ((idx % TOTAL) + TOTAL) % TOTAL;
    applyLayout(true);
    clearInterval(timer);
    startTimer();
  }

  function startTimer() {
    timer = setInterval(() => goTo(current + 1), 4000);
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dotEls.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  window.addEventListener('resize', () => applyLayout(false));

  // Place slides instantly (no animation), then enable transitions
  applyLayout(false);
  requestAnimationFrame(() => requestAnimationFrame(() => applyLayout(true)));
  startTimer();
</script>
