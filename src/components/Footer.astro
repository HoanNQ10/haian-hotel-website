        src="/images/logo/logo-1.jpg"
        alt="Hải An Hotel"
        class="h-14 w-auto object-contain brightness-0 invert"
      />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- About -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wide mb-3 text-white/80">Về Chúng Tôi</h3>
        <p class="text-sm text-white/70">
          Một khách sạn gia đình nhỏ, sạch sẽ và ấm cúng với đội ngũ thân thiện.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold mb-3">Liên Kết Nhanh</h4>
