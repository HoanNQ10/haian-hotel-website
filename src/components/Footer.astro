          <li><a href="#tien-nghi" class="hover:text-accent">Tiện Nghi</a></li>
          <li><a href="#hinh-anh" class="hover:text-accent">Thư Viện Ảnh</a></li>
          <li><a href="#lien-he" class="hover:text-accent">Liên Hệ</a></li>
