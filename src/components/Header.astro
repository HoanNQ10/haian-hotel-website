---
import Button from './Button.astro';
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-container mx-auto px-4 md:px-0 py-4 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center">
      <h1 class="text-xl font-bold text-primary">HẢI AN HOTEL</h1>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8 flex-1 justify-center">
      <a href="#gioi-thieu" class="text-text-muted hover:text-primary text-sm">Giới Thiệu</a>
      <a href="#phong-tro" class="text-text-muted hover:text-primary text-sm">Phòng Trọ</a>
      <a href="#tien-nghi" class="text-text-muted hover:text-primary text-sm">Tiện Nghi</a>
      <a href="#vi-tri" class="text-text-muted hover:text-primary text-sm">Vị Trí</a>
      <a href="#lien-he" class="text-text-muted hover:text-primary text-sm">Liên Hệ</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-primary text-2xl"
      aria-label="Toggle menu"
    >
      ☰
    </button>

    <!-- Contact Button -->
    <Button variant="accent" size="sm" class="hidden sm:inline-flex">
      ☎ Gọi Ngay
    </Button>
  </div>

  <!-- Mobile Navigation Menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-border-warm"
  >
    <div class="max-w-container mx-auto px-4 py-4 space-y-3">
      <a href="#gioi-thieu" class="block text-text-muted hover:text-primary text-sm py-2">Giới Thiệu</a>
      <a href="#phong-tro" class="block text-text-muted hover:text-primary text-sm py-2">Phòng Trọ</a>
      <a href="#tien-nghi" class="block text-text-muted hover:text-primary text-sm py-2">Tiện Nghi</a>
      <a href="#vi-tri" class="block text-text-muted hover:text-primary text-sm py-2">Vị Trí</a>
      <a href="#lien-he" class="block text-text-muted hover:text-primary text-sm py-2">Liên Hệ</a>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
