---
---

<header class="bg-surface fixed top-0 left-0 right-0 z-50 border-b border-border">
  <div class="relative px-4 md:px-8 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center hover:opacity-80 transition-opacity duration-200">
      <img
        src="/images/logo/logo-1.jpg"
        alt="Hải An Hotel"
        class="h-12 md:h-14 w-auto max-w-[140px] md:max-w-[160px] object-contain"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8 absolute left-1/2 -translate-x-1/2 items-center">
      <a href="/#gioi-thieu" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
        Giới Thiệu
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
      </a>

      <!-- Cơ Sở with dropdown -->
      <div class="relative group/cosо flex items-center">
        <a href="/#co-so" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
          Cơ Sở
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
        </a>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/cosо:opacity-100 group-hover/cosо:visible transition-all duration-200 z-50">
          <div class="bg-surface border border-border rounded-xl shadow-lg py-2 w-56">
            <a href="/#co-so" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Hải An Villa Đà Lạt
            </a>
            <a href="/#co-so" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Hải An Hotel Bảo Lộc
            </a>
            <a href="/#co-so" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Hải An Homestay Bảo Lộc
            </a>
          </div>
        </div>
      </div>
      <div class="relative group/phong flex items-center">
        <a href="/phong-nghi" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
          Phòng Nghỉ
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
        </a>
      </div>
      <div class="relative group/tienich flex items-center">
        <a href="/tien-ich" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
          Dịch vụ
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
        </a>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/tienich:opacity-100 group-hover/tienich:visible transition-all duration-200 z-50">
          <div class="bg-surface border border-border rounded-xl shadow-lg py-2 w-44">
            <a href="/tien-ich" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Spa
            </a>
            <a href="/tien-ich" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Thuê Xe
            </a>
            <a href="/tien-ich" class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              Đưa Đón
            </a>
          </div>
        </div>
      </div>
      <a href="/#blog" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
        Ăn Uống
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="/#vi-tri" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
        Vị Trí
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="/lien-he" class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 relative group">
        Liên Hệ
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
      </a>
    </nav>

    <!-- Desktop Right Side: Language + Phone -->
    <div class="hidden md:flex items-center gap-6">
      <div class="relative group/lang">
        <button class="text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 flex items-center gap-1">
          VI
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 z-50">
          <div class="bg-surface border border-border rounded-xl shadow-lg py-1 w-36">
            <button class="w-full text-left px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">EN</button>
            <button class="w-full text-left px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">JP</button>
            <button class="w-full text-left px-4 py-2.5 text-sm text-text-muted hover:text-primary hover:bg-accent-soft transition-colors duration-150">ZH</button>
          </div>
        </div>
      </div>
      <a href="tel:0986166966" class="border-l border-border pl-6 text-text-muted hover:text-primary text-base font-medium transition-colors duration-200 flex items-center gap-2">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        0986 166 966
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-primary text-2xl hover:text-accent transition-colors duration-200"
      aria-label="Toggle menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Navigation Menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden bg-surface border-t border-border"
  >
    <div class="max-w-container mx-auto px-4 py-4 space-y-2">
      <a href="/#gioi-thieu" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Giới Thiệu</a>
      <a href="/#co-so" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Cơ Sở</a>
      <a href="/phong-nghi" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Phòng Nghỉ</a>
      <a href="/tien-ich" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Dịch vụ</a>
      <a href="/#blog" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Ăn Uống</a>
      <a href="/#vi-tri" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Vị Trí</a>
      <a href="/lien-he" class="block text-text-muted hover:text-primary hover:bg-accent-soft text-sm py-3 px-3 rounded-lg transition-all duration-200 font-medium">Liên Hệ</a>
    </div>
  </nav>
</header>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
