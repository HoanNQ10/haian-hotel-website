---
interface Props {
  title?: string;
  name: string;
  capacity?: string;
  priceDay?: number;
  priceHourly?: number;
  amenities?: string[];
  image?: string;
  description?: string;
}

const {
  title,
  name,
  capacity,
  priceDay,
  priceHourly,
  amenities = [],
  image = 'https://via.placeholder.com/400x300?text=Room',
  description
} = Astro.props;

const formatPrice = (price: number | undefined) => {
  if (!price) return '';
  return new Intl.NumberFormat('vi-VN', {
    style: 'currency',
    currency: 'VND',
    maximumFractionDigits: 0
  }).format(price);
};
---

<div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  <img
    src={image}
    alt={name}
    class="w-full h-56 object-cover"
  />
  <div class="p-6">
    {title && <p class="text-sm text-accent font-medium uppercase tracking-wide mb-2">{title}</p>}
    <h3 class="text-xl font-semibold text-primary mb-2">{name}</h3>

    {description && <p class="text-text-muted text-sm mb-4">{description}</p>}

    {capacity && <p class="text-sm text-text-muted mb-3">👥 {capacity}</p>}

    {amenities.length > 0 && (
      <div class="mb-4">
        <p class="text-xs font-semibold text-primary uppercase mb-2">Tiện nghi</p>
        <div class="flex flex-wrap gap-2">
          {amenities.map(amenity => (
            <span class="text-xs bg-accent-soft text-primary px-2 py-1 rounded">
              {amenity}
            </span>
          ))}
        </div>
      </div>
    )}

    {(priceDay || priceHourly) && (
      <div class="mb-4">
        {priceDay && <p class="text-lg font-semibold text-accent">Theo ngày: {formatPrice(priceDay)}</p>}
        {priceHourly && <p class="text-sm text-text-muted">Theo giờ: {formatPrice(priceHourly)}</p>}
      </div>
    )}

    <a
      href="tel:TBD"
      class="block text-center bg-primary text-white px-4 py-2 rounded text-sm font-medium hover:bg-primary-dark transition-colors"
    >
      Liên hệ đặt phòng
    </a>
  </div>
</div>
