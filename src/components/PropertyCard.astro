---
interface Props {
  name: string;
  description: string;
  ctaText: string;
  ctaHref?: string;
  image?: string;
}

const { name, description, ctaText, ctaHref = '#', image } = Astro.props;
---

<div class="bg-white flex flex-col">

  <!-- Image -->
  <div class="overflow-hidden h-[380px] group">
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-accent-soft to-border flex items-center justify-center">
        <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="pt-6 pb-5 px-4 flex flex-col flex-1 items-center border-t border-border text-center">
    <h3 class="text-xl font-heading font-bold text-primary mb-3 leading-snug">
      {name}
    </h3>
    <p class="text-text-muted text-sm leading-relaxed flex-1 mb-5">
      {description}
    </p>
    <a
      href={ctaHref}
      class="group/cta inline-flex items-center gap-1.5 text-accent hover:text-white border border-accent hover:bg-accent text-sm font-semibold tracking-wider uppercase transition-all duration-300 py-2.5 px-7 whitespace-nowrap"
    >
      {ctaText}
      <span class="transition-transform duration-200 group-hover/cta:translate-x-1">→</span>
    </a>
  </div>

</div>
