---
interface Props {
  name: string;
  location?: string;
  description: string;
  ctaText: string;
  ctaHref?: string;
  image?: string;
}

const { name, location, description, ctaText, ctaHref = '#', image } = Astro.props;
---

<div class="flex flex-col h-full">

  <!-- Image -->
  <div class="overflow-hidden group" style="height: 440px; flex-shrink: 0;">
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-accent-soft to-border flex items-center justify-center">
        <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Detail -->
  <div class="bg-white flex flex-col flex-1 pt-4 pr-5 pb-5 pl-0 text-left">

    <!-- Title -->
    <h3 class="font-bold text-primary leading-snug mb-1" style="font-size: 1.5rem;">
      {name}
    </h3>

    <!-- Location -->
    {location && (
      <p class="text-xs tracking-[0.12em] uppercase text-accent font-medium mb-3">{location}</p>
    )}

    <!-- Description -->
    <p class="text-text-muted leading-relaxed flex-1 mb-5 text-sm">
      {description}
    </p>

    <!-- Bottom: CTA right-aligned -->
    <div class="flex justify-end">
      <a
        href={ctaHref}
        class="group/cta inline-flex items-center gap-2 bg-primary hover:bg-primary/85 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 whitespace-nowrap"
      >
        {ctaText}
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>

</div>
