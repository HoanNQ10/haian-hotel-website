---
interface Props {
  image?: string;
  imageAlt?: string;
  title?: string;
  description?: string;
}

const {
  image = 'https://via.placeholder.com/400x300?text=Placeholder',
  imageAlt = 'Placeholder image',
  title,
  description
} = Astro.props;
---

<div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  {image && (
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-48 object-cover"
    />
  )}
  <div class="p-6">
    {title && <h3 class="text-lg font-semibold text-primary mb-2">{title}</h3>}
    {description && <p class="text-text-muted text-sm leading-relaxed">{description}</p>}
    <slot />
  </div>
</div>
