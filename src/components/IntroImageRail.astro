---
const images = [
  { src: '/images/gioi-thieu/IMG_975.jpg',  alt: 'Hải An Villa Hotel' },
  { src: '/images/gioi-thieu/IMG_999.jpg',  alt: 'Hải An Villa Hotel' },
  { src: '/images/gioi-thieu/IMG_9993.JPG', alt: 'Hải An Villa Hotel' },
];
---

<div id="intro-rail" class="absolute inset-0 overflow-hidden">
  <div id="intro-track" class="flex h-full" style="will-change:transform;">

    <!-- clone of last (for prev loop) -->
    <div class="flex-shrink-0 h-full">
      <img src={images.at(-1)!.src} alt={images.at(-1)!.alt} class="w-full h-full object-cover" />
    </div>

    {images.map((img) => (
      <div class="flex-shrink-0 h-full">
        <img src={img.src} alt={img.alt} class="w-full h-full object-cover" />
      </div>
    ))}

    <!-- clone of first (for next loop) -->
    <div class="flex-shrink-0 h-full">
      <img src={images[0].src} alt={images[0].alt} class="w-full h-full object-cover" />
    </div>

  </div>
</div>

<script>
  (function () {
    const rail    = document.getElementById('intro-rail');
    const track   = document.getElementById('intro-track') as HTMLElement;
    const prevBtn = document.getElementById('intro-prev-btn');
    const nextBtn = document.getElementById('intro-next-btn');
    if (!rail || !track) return;

    const items  = Array.from(track.children) as HTMLElement[];
    const REAL   = items.length - 2;   // 3 real images
    const ITEM_R = 0.74;               // each item = 74% of rail width → 13% peek each side

    let cur   = 1;                     // index 1 = first real image
    let timer: ReturnType<typeof setInterval>;

    function setWidths() {
      const iW = Math.round(rail!.offsetWidth * ITEM_R);
      items.forEach(el => { el.style.width = iW + 'px'; });
    }

    function translate(animated: boolean) {
      const W  = rail!.offsetWidth;
      const iW = Math.round(W * ITEM_R);
      const tx = W / 2 - iW / 2 - cur * iW;
      track.style.transition = animated ? 'transform 700ms ease-in-out' : 'none';
      track.style.transform  = `translateX(${tx}px)`;
    }

    function updateOpacity() {
      items.forEach((el, i) => {
        el.style.transition = 'opacity 700ms ease-in-out';
        el.style.opacity    = i === cur ? '1' : '0.65';
      });
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(goNext, 4000);
    }

    function goNext() { cur++; translate(true); updateOpacity(); resetTimer(); }
    function goPrev() { cur--; translate(true); updateOpacity(); resetTimer(); }

    track.addEventListener('transitionend', () => {
      if (cur === REAL + 1) { cur = 1;    translate(false); updateOpacity(); }
      if (cur === 0)        { cur = REAL; translate(false); updateOpacity(); }
    });

    prevBtn?.addEventListener('click', goPrev);
    nextBtn?.addEventListener('click', goNext);
    window.addEventListener('resize', () => { setWidths(); translate(false); });

    setWidths();
    translate(false);
    updateOpacity();
    resetTimer();
  })();
</script>
