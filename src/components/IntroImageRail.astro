---
const images = [
  { src: '/images/gioi-thieu/IMG_975.jpg',  alt: 'Hải An Villa Hotel' },
  { src: '/images/gioi-thieu/IMG_999.jpg',  alt: 'Hải An Villa Hotel' },
  { src: '/images/gioi-thieu/IMG_9993.JPG', alt: 'Hải An Villa Hotel' },
];
---

<div id="intro-rail" style="width:100%; position:relative;">
  <div id="intro-row" style="display:flex; align-items:center; width:100%;">

    <!-- Left side slot -->
    <div
      id="side-left"
      style="flex-shrink:0; width:17%; height:clamp(320px, 37vw, 540px); position:relative; background:white; padding:10px;"
    >
      <div style="position:relative; width:100%; height:100%; overflow:hidden;">
        <img data-slot="left" data-layer="a" src={images[2].src} alt={images[2].alt}
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;display:block;opacity:1;z-index:2;transition:opacity 800ms ease, transform 800ms ease;" />
        <img data-slot="left" data-layer="b" src={images[2].src} alt={images[2].alt}
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;display:block;opacity:0;z-index:1;transition:opacity 800ms ease, transform 800ms ease;" />
      </div>
    </div>

    <!-- Center main slot -->
    <div
      id="center-slot"
      style="flex:1; z-index:10; padding:0 14px;"
    >
      <div style="background:white; padding:12px; height:clamp(380px, 43vw, 620px); position:relative;">
        <div style="position:relative; width:100%; height:100%; overflow:hidden;">
          <img data-slot="center" data-layer="a" src={images[0].src} alt={images[0].alt}
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;opacity:1;z-index:2;transition:opacity 800ms ease, transform 800ms ease;" />
          <img data-slot="center" data-layer="b" src={images[0].src} alt={images[0].alt}
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;opacity:0;z-index:1;transition:opacity 800ms ease, transform 800ms ease;" />
        </div>
      </div>
    </div>

    <!-- Right side slot -->
    <div
      id="side-right"
      style="flex-shrink:0; width:17%; height:clamp(320px, 37vw, 540px); position:relative; background:white; padding:10px;"
    >
      <div style="position:relative; width:100%; height:100%; overflow:hidden;">
        <img data-slot="right" data-layer="a" src={images[1].src} alt={images[1].alt}
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:left center;display:block;opacity:1;z-index:2;transition:opacity 800ms ease, transform 800ms ease;" />
        <img data-slot="right" data-layer="b" src={images[1].src} alt={images[1].alt}
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:left center;display:block;opacity:0;z-index:1;transition:opacity 800ms ease, transform 800ms ease;" />
      </div>
    </div>

  </div>
</div>

<script>
  (function () {
    const srcs = [
      '/images/gioi-thieu/IMG_975.jpg',
      '/images/gioi-thieu/IMG_999.jpg',
      '/images/gioi-thieu/IMG_9993.JPG',
    ];
    const N = srcs.length;

    const SLOTS = ['left', 'center', 'right'] as const;
    type SlotName = typeof SLOTS[number];

    const layers: Record<SlotName, 'a' | 'b'> = { left: 'a', center: 'a', right: 'a' };

    function getImg(slot: SlotName, layer: 'a' | 'b'): HTMLImageElement | null {
      return document.querySelector<HTMLImageElement>(`[data-slot="${slot}"][data-layer="${layer}"]`);
    }

    const prevBtn = document.getElementById('intro-prev-btn');
    const nextBtn = document.getElementById('intro-next-btn');

    let cur = 0;
    let timer: ReturnType<typeof setInterval>;

    function setSlots(animate: boolean) {
      const newSrcs: Record<SlotName, string> = {
        left:   srcs[(cur - 1 + N) % N],
        center: srcs[cur],
        right:  srcs[(cur + 1) % N],
      };

      SLOTS.forEach(slot => {
        const active = layers[slot];
        const next   = active === 'a' ? 'b' : 'a';
        const imgA   = getImg(slot, active);
        const imgN   = getImg(slot, next);
        if (!imgA || !imgN) return;

        imgN.src = newSrcs[slot];

        if (!animate) {
          imgN.style.transition = 'none';
          imgA.style.transition = 'none';
          imgN.style.opacity = '1'; imgN.style.transform = 'translateY(0)'; imgN.style.zIndex = '2';
          imgA.style.opacity = '0'; imgA.style.transform = 'translateY(0)'; imgA.style.zIndex = '1';
          layers[slot] = next;
          return;
        }

        // Park incoming: offset down + invisible
        imgN.style.transition = 'none';
        imgN.style.opacity = '0';
        imgN.style.transform = 'translateY(18px)';
        imgN.style.zIndex = '2';
        imgA.style.zIndex = '1';

        imgN.offsetWidth; // force reflow

        // Slide-fade in new, drift-fade out old
        imgN.style.transition = 'opacity 700ms ease-in-out, transform 700ms ease-in-out';
        imgA.style.transition = 'opacity 700ms ease-in-out, transform 700ms ease-in-out';
        imgN.style.opacity = '1'; imgN.style.transform = 'translateY(0)';
        imgA.style.opacity = '0'; imgA.style.transform = 'translateY(-10px)';

        layers[slot] = next;
      });
    }

    function goTo(idx: number) {
      cur = ((idx % N) + N) % N;
      setSlots(true);
      clearInterval(timer);
      timer = setInterval(() => goTo(cur + 1), 4000);
    }

    prevBtn?.addEventListener('click', () => goTo(cur - 1));
    nextBtn?.addEventListener('click', () => goTo(cur + 1));

    timer = setInterval(() => goTo(cur + 1), 4000);
  })();
</script>
