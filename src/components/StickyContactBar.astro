---
import Button from './Button.astro';
---

<div class="fixed bottom-0 left-0 right-0 md:hidden bg-white border-t border-border-warm shadow-lg z-40">
  <div class="max-w-container mx-auto px-0 py-3 flex gap-2">
    <a
      href="tel:TBD"
      class="flex-1 flex items-center justify-center gap-2 bg-primary text-white px-4 py-3 rounded font-medium text-sm hover:bg-primary-dark transition-colors"
    >
      📞 Gọi
    </a>
    <a
      href="https://zalo.me/TBD"
      class="flex-1 flex items-center justify-center gap-2 bg-accent text-white px-4 py-3 rounded font-medium text-sm hover:bg-accent transition-colors"
    >
      💬 Zalo
    </a>
    <a
      href="https://maps.google.com/?q=TBD"
      class="flex-1 flex items-center justify-center gap-2 border border-primary text-primary bg-white px-4 py-3 rounded font-medium text-sm hover:bg-accent-soft transition-colors"
    >
      🗺️ Bản Đồ
    </a>
  </div>
</div>

<!-- Spacer to prevent content being hidden behind sticky bar -->
<div class="md:hidden h-20"></div>
