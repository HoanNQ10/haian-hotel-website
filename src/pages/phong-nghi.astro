---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const roomTypes = [
  {
    name: "Phòng Đơn",
    description: "Phòng đơn gọn gàng, thoáng mát — phù hợp cho khách đi một mình hoặc công tác. Một số phòng có ban công riêng nhìn ra không gian xanh.",
    bedType: "1 giường đơn",
    capacity: "1–2 người",
    floors: "Tầng 1, Tầng 2, Tầng hầm 1",
    rooms: ["201", "203", "301", "302", "303", "304", "B102"],
    detailHref: "/phong-don",
    gradient: "bg-gradient-to-br from-accent-soft to-border"
  },
  {
    name: "Phòng Đôi",
    description: "Phòng rộng rãi với 2 giường đơn — lý tưởng cho gia đình nhỏ hoặc nhóm bạn. Một số phòng có ban công riêng, ánh sáng tự nhiên tràn vào thoáng mát.",
    bedType: "2 giường đơn",
    capacity: "3–4 người",
    floors: "Tầng trệt, Tầng 1, Tầng hầm 1, Tầng hầm 2",
    rooms: ["101", "102", "202", "204", "B101", "B201", "B202"],
    detailHref: "/phong-doi",
    gradient: "bg-gradient-to-br from-accent/20 to-accent-soft"
  }
];
---

<Layout title="Phòng Nghỉ — Hải An Villa Hotel" description="Các loại phòng nghỉ tại Hải An Villa Đà Lạt — phòng đơn, phòng đôi, có hoặc không có ban công.">
  <Header />

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[400px] md:min-h-[480px] flex items-center justify-center" aria-label="Phòng nghỉ">
    <!-- Background gradient placeholder — replace src with real image -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary/60 to-accent/40" aria-hidden="true"></div>
    <!-- Dark overlay for text contrast -->
    <div class="absolute inset-0 bg-primary/40" aria-hidden="true"></div>
    <!-- Content -->
    <div class="relative text-center px-4 md:px-8">
      <p class="text-white/70 text-sm uppercase tracking-widest mb-3">Hải An Villa Đà Lạt</p>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">Phòng Nghỉ</h1>
      <div class="w-12 h-0.5 bg-accent mx-auto mb-5"></div>
      <p class="text-white/75 text-base md:text-lg max-w-lg mx-auto leading-relaxed">
        Sạch sẽ, ấm cúng, đầy đủ tiện nghi — không gian nghỉ ngơi lý tưởng giữa lòng Đà Lạt.
      </p>
    </div>
  </section>

  {roomTypes.map((room, index) => (
    <section
      class={`${index % 2 === 0 ? 'bg-surface' : 'bg-background'}${index < roomTypes.length - 1 ? ' border-b border-border' : ''}`}
      aria-label={room.name}
    >
      <div class="max-w-container mx-auto px-4 md:px-8 py-14 md:py-20">
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

          <!-- Image -->
          <div
            class={`rounded-2xl aspect-[4/3] ${room.gradient}${index % 2 !== 0 ? ' md:order-2' : ''}`}
            aria-hidden="true"
          ></div>

          <!-- Content -->
          <div class={index % 2 !== 0 ? 'md:order-1' : ''}>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary mb-3">{room.name}</h2>
            <div class="w-10 h-0.5 bg-accent mb-5"></div>
            <p class="text-text-muted leading-relaxed mb-7">{room.description}</p>

            <!-- Specs with divider rows -->
            <div class="divide-y divide-border text-sm mb-7">
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7h18M3 7v10h18V7M3 11h18"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Loại giường</span>
                <span class="text-primary font-medium">{room.bedType}</span>
              </div>
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Sức chứa</span>
                <span class="text-primary font-medium">{room.capacity}</span>
              </div>
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3M9 7h1m-1 4h1m4-4h1m-1 4h1"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Vị trí</span>
                <span class="text-primary font-medium">{room.floors}</span>
              </div>
            </div>

            <!-- Amenity pills -->
            <div class="flex flex-wrap gap-2 mb-8">
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">WiFi miễn phí</span>
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">Điều hòa</span>
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">Nước nóng</span>
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">TV</span>
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">WC riêng</span>
              <span class="text-xs bg-accent-soft text-primary px-3 py-1.5 rounded-full font-medium">Ban công*</span>
            </div>

            <!-- CTA -->
            <div class="flex gap-3 flex-wrap">
              <a
                href={room.detailHref}
                class="inline-flex items-center justify-center bg-primary text-white px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:bg-primary/90 transition-all duration-200"
              >
                Xem Chi Tiết
              </a>
              <a
                href="/lien-he"
                class="inline-flex items-center justify-center border border-border text-text-muted bg-transparent px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:border-primary hover:text-primary transition-all duration-200"
              >
                Liên Hệ
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>
  ))}

  <Footer />
</Layout>
