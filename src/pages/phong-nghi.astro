---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const roomTypes = [
  {
    name: "Phòng Đơn",
    description: "Phòng đơn gọn gàng, thoáng mát — phù hợp cho khách đi một mình hoặc công tác. Một số phòng có ban công riêng nhìn ra không gian xanh.",
    bedType: "1 giường đơn",
    capacity: "1–2 người",
    floors: "Tầng 1, Tầng 2, Tầng hầm 1",
    rooms: ["201", "203", "301", "302", "303", "304", "B102"],
    detailHref: "/phong-don",
    gradient: "bg-gradient-to-br from-accent-soft to-border"
  },
  {
    name: "Phòng Đôi",
    description: "Phòng rộng rãi với 2 giường đơn — lý tưởng cho gia đình nhỏ hoặc nhóm bạn. Một số phòng có ban công riêng, ánh sáng tự nhiên tràn vào thoáng mát.",
    bedType: "2 giường đơn",
    capacity: "3–4 người",
    floors: "Tầng trệt, Tầng 1, Tầng hầm 1, Tầng hầm 2",
    rooms: ["101", "102", "202", "204", "B101", "B201", "B202"],
    detailHref: "/phong-doi",
    gradient: "bg-gradient-to-br from-accent/20 to-accent-soft"
  }
];
---

<Layout title="Phòng Nghỉ — Hải An Villa Hotel" description="Các loại phòng nghỉ tại Hải An Villa Đà Lạt — phòng đơn, phòng đôi, có hoặc không có ban công.">
  <Header />

  {roomTypes.map((room, index) => (
    <section
      class={`${index % 2 === 0 ? 'bg-surface' : 'bg-background'}${index < roomTypes.length - 1 ? ' border-b border-border' : ''}`}
      aria-label={room.name}
    >
      <div class="max-w-container mx-auto px-4 md:px-8 py-14 md:py-20">
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

          <!-- Image -->
          <div
            class={`rounded-2xl aspect-[4/3] ${room.gradient}${index % 2 !== 0 ? ' md:order-2' : ''}`}
            aria-hidden="true"
          ></div>

          <!-- Content -->
          <div class={index % 2 !== 0 ? 'md:order-1' : ''}>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary mb-3">{room.name}</h2>
            <div class="w-10 h-0.5 bg-accent mb-5"></div>
            <p class="text-text-muted leading-relaxed mb-6">{room.description}</p>

            <!-- Detail grid -->
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm mb-6">
              <dt class="text-text-muted">Loại giường</dt>
              <dd class="text-primary font-medium">{room.bedType}</dd>
              <dt class="text-text-muted">Sức chứa</dt>
              <dd class="text-primary font-medium">{room.capacity}</dd>
              <dt class="text-text-muted">Vị trí</dt>
              <dd class="text-primary font-medium">{room.floors}</dd>
            </dl>

            <!-- Amenity list -->
            <ul class="grid grid-cols-2 gap-x-4 gap-y-2 mb-6">
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>
                </svg>
                WiFi miễn phí
              </li>
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v18M8 7l4-4 4 4M8 17l4 4 4-4M3 12h18M7 8l-4 4 4 4M17 8l4 4-4 4"/>
                </svg>
                Điều hòa
              </li>
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Nước nóng
              </li>
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                TV
              </li>
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 10V6a1 1 0 011-1h16a1 1 0 011 1v4M3 10l2 10h14l2-10"/>
                </svg>
                WC riêng
              </li>
              <li class="flex items-center gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12V8h18v4M3 12v4h18v-4M7 12v4M12 12v4M17 12v4"/>
                </svg>
                Ban công (một số phòng)
              </li>
            </ul>

            <!-- CTA -->
            <div class="flex gap-3 flex-wrap">
              <a
                href={room.detailHref}
                class="inline-flex items-center justify-center border border-primary text-primary bg-transparent px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:bg-primary hover:text-white transition-all duration-200"
              >
                Xem Chi Tiết
              </a>
              <a
                href="/lien-he"
                class="inline-flex items-center justify-center border border-border text-text-muted bg-transparent px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:border-primary hover:text-primary transition-all duration-200"
              >
                Liên Hệ Đặt Phòng
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>
  ))}

  <Footer />
</Layout>
