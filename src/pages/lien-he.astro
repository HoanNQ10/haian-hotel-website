---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const properties = [
  {
    name: "Hải An Villa Đà Lạt",
    address: "TBD, Đà Lạt, Lâm Đồng",
    phone: "TBD",
    zalo: "TBD",
    mapsUrl: "https://maps.google.com/?q=Da+Lat+Vietnam",
    gradient: "bg-gradient-to-br from-accent-soft to-border"
  },
  {
    name: "Hải An Hotel Bảo Lộc",
    address: "TBD, Bảo Lộc, Lâm Đồng",
    phone: "TBD",
    zalo: "TBD",
    mapsUrl: "https://maps.google.com/?q=Bao+Loc+Vietnam",
    gradient: "bg-gradient-to-br from-primary/10 to-primary/20"
  },
  {
    name: "Hải An Homestay Bảo Lộc",
    address: "TBD, Bảo Lộc, Lâm Đồng",
    phone: "TBD",
    zalo: "TBD",
    mapsUrl: "https://maps.google.com/?q=Bao+Loc+Vietnam",
    gradient: "bg-gradient-to-br from-accent/20 to-accent-soft"
  }
];

const isTBD = (v: string) => v === 'TBD';
---

<Layout title="Liên Hệ — Hải An Villa Hotel" description="Thông tin liên hệ và địa chỉ các cơ sở lưu trú Hải An tại Đà Lạt và Bảo Lộc.">
  <Header />

  <!-- Page Hero -->
  <section class="bg-surface border-b border-border">
    <div class="max-w-container mx-auto px-4 md:px-8 py-10">
      <a href="/" class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-primary transition-colors duration-200 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Trang Chủ
      </a>
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-primary mb-3">Liên Hệ</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-text-muted max-w-xl">Thông tin liên hệ các cơ sở lưu trú Hải An.</p>
    </div>
  </section>

  <!-- Property Cards -->
  <section class="bg-background">
    <div class="max-w-container mx-auto px-4 md:px-8 py-14">
      <div class="space-y-12">
        {properties.map((property, index) => (
          <>
            <div class="grid grid-cols-1 md:grid-cols-[55%_45%] gap-8 md:gap-12 items-center">
              <!-- Left: contact info -->
              <div>
                <h2 class="text-2xl font-heading font-bold text-primary mb-6">{property.name}</h2>
                <div class="space-y-4 mb-8">
                  <div class="flex items-start gap-3 text-text-muted">
                    <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span>{property.address}</span>
                  </div>
                  {isTBD(property.phone) ? (
                    <div class="flex items-center gap-3 text-text-muted/50">
                      <svg class="w-5 h-5 flex-shrink-0 text-accent/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                      </svg>
                      <span>Điện thoại — cập nhật sau</span>
                    </div>
                  ) : (
                    <a href={`tel:${property.phone}`} class="flex items-center gap-3 text-text-muted hover:text-primary transition-colors duration-200">
                      <svg class="w-5 h-5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                      </svg>
                      <span>{property.phone}</span>
                    </a>
                  )}
                  {isTBD(property.zalo) ? (
                    <div class="flex items-center gap-3 text-text-muted/50">
                      <svg class="w-5 h-5 flex-shrink-0 text-accent/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                      </svg>
                      <span>Zalo — cập nhật sau</span>
                    </div>
                  ) : (
                    <a href={`https://zalo.me/${property.zalo}`} class="flex items-center gap-3 text-text-muted hover:text-primary transition-colors duration-200">
                      <svg class="w-5 h-5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                      </svg>
                      <span>Zalo: {property.zalo}</span>
                    </a>
                  )}
                </div>
                <div class="flex flex-wrap gap-3">
                  {!isTBD(property.phone) && (
                    <a
                      href={`tel:${property.phone}`}
                      class="inline-flex items-center justify-center gap-2 border border-primary text-primary bg-transparent px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-accent-soft transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0"
                    >
                      Gọi Ngay
                    </a>
                  )}
                  {!isTBD(property.zalo) && (
                    <a
                      href={`https://zalo.me/${property.zalo}`}
                      class="inline-flex items-center justify-center gap-2 bg-accent text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-accent-dark transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
                    >
                      Nhắn Zalo
                    </a>
                  )}
                  <a
                    href={property.mapsUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 border border-primary text-primary bg-transparent px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-accent-soft transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0"
                  >
                    Xem Bản Đồ
                  </a>
                </div>
              </div>
              <!-- Right: map placeholder -->
              <div class={`w-full aspect-video rounded-xl flex items-center justify-center ${property.gradient}`}>
                <p class="text-primary/40 text-sm">Google Map — cập nhật sau</p>
              </div>
            </div>
            {index < properties.length - 1 && <hr class="border-border" />}
          </>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
