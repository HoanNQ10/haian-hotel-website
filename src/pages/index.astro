---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import Section from '../components/Section.astro';
import IntroImageRail from '../components/IntroImageRail.astro';
import PropertyCard from '../components/PropertyCard.astro';
import Footer from '../components/Footer.astro';
import StickyContactBar from '../components/StickyContactBar.astro';
---

<Layout title="Hải An Villa Hotel - Khách Sạn Gia Đình Sạch Sẽ Tại [Địa Chỉ]">
  <Header />

  <!-- Hero Image Carousel -->
  <HeroCarousel />

  <!-- Giới Thiệu -->
  <section id="gioi-thieu" class="bg-[#FDFAF7] overflow-hidden" style="padding: clamp(24px, 3vh, 48px) 0;">
    <div class="flex flex-col md:flex-row mx-auto w-full" style="max-width:1440px; height: clamp(640px, 82vh, 920px);">

      <!-- Left: text (40%) — vertically centered -->
      <div class="md:w-[40%] flex items-center py-10 md:py-0" style="padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(16px, 2vw, 40px);">
        <div style="max-width: clamp(360px, 30vw, 540px);">
          <h2 class="font-heading font-bold text-primary mb-4 leading-tight" style="font-size: clamp(20px, 1.8vw, 30px); margin-top: 8em;">
            Chào Mừng Đến Với Hải An
          </h2>
          <div class="w-12 h-0.5 bg-accent mb-6"></div>
          <p class="text-text-muted leading-relaxed mb-4" style="font-size: clamp(14px, 1.05vw, 17px);">
            Hải An là hệ thống khách sạn gia đình với tiêu chí sạch sẽ, ấm cúng và thân thiện.
            Chúng tôi mang đến không gian lưu trú thoải mái, dịch vụ chân thành và giá cả hợp lý —
            lý tưởng cho những chuyến nghỉ dưỡng tại Đà Lạt và Bảo Lộc.
          </p>
          <p class="text-text-muted leading-relaxed mb-10" style="font-size: clamp(14px, 1.05vw, 17px);">
            Với đội ngũ nhân viên nhiệt tình, chúng tôi luôn sẵn sàng hỗ trợ để mỗi kỳ nghỉ của bạn
            trở thành những kỷ niệm đáng nhớ.
          </p>
          <!-- Arrow navigation -->
          <div class="flex gap-3">
            <button
              id="intro-prev-btn"
              class="w-11 h-11 rounded-full border border-border flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200"
              aria-label="Ảnh trước"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            <button
              id="intro-next-btn"
              class="w-11 h-11 rounded-full border border-border flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200"
              aria-label="Ảnh tiếp"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Right: editorial peek carousel (60%) -->
      <div class="md:flex-1 flex items-center overflow-hidden" style="min-height: clamp(260px, 55vw, 820px);">
        <IntroImageRail />
      </div>

    </div>
  </section>

  <!-- Properties Section -->
  <section id="co-so" class="bg-[#f8f5f0]">
    <div class="py-16 md:py-24 mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">
      <div class="mb-12 text-center fade-item">
        <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-3">Hải An</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Cơ Sở Lưu Trú
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3 mx-auto"></div>
        <p class="text-text-muted text-sm mt-3">Hệ thống lưu trú của Hải An tại Đà Lạt và Bảo Lộc</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="fade-item" style="transition-delay: 0ms;">
          <PropertyCard
            name="Hải An Villa Đà Lạt"
            description="Khách sạn gia đình tại trung tâm Đà Lạt — phòng sạch sẽ, đội ngũ thân thiện, giá hợp lý."
            ctaText="Xem Phòng"
            ctaHref="/phong-nghi"
            image="/images/co-so/coso-1.jpg"
          />
        </div>
        <div class="fade-item" style="transition-delay: 120ms;">
          <PropertyCard
            name="Hải An Hotel Bảo Lộc"
            description="Khách sạn gia đình tại Bảo Lộc — không gian yên tĩnh, sạch sẽ, giá cả phải chăng."
            ctaText="Liên Hệ"
            ctaHref="/lien-he"
            image="/images/co-so/coso-2.jpg"
          />
        </div>
        <div class="fade-item" style="transition-delay: 240ms;">
          <PropertyCard
            name="Hải An Homestay Bảo Lộc"
            description="Homestay ấm cúng tại Bảo Lộc — trải nghiệm gần gũi, không gian xanh mát."
            ctaText="Liên Hệ"
            ctaHref="/lien-he"
            image="/images/co-so/coso-3.jpg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Editorial Hub Section -->
  <section id="kham-pha" class="bg-[#FDFAF7] py-20 md:py-28">
    <div class="mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">

      <!-- Section label -->
      <div class="mb-12 text-center fade-item">
        <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-3">Hải An</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Khám Phá Thêm Tại Hải An
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3 mx-auto"></div>
        <p class="text-text-muted text-sm mt-3">Dịch vụ, ẩm thực và cẩm nang du lịch dành cho bạn</p>
      </div>

      <!-- Row 1: Text block left + Image block right -->
      <div class="flex flex-col lg:flex-row gap-5 mb-5 fade-item">

        <!-- Left: Dịch vụ & Tiện ích — text block (~42%) -->
        <div class="lg:w-[42%] bg-[#ede8df] flex flex-col justify-between p-10 md:p-14" style="min-height:420px;">
          <div>
            <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
              Dịch vụ
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Spa, thuê xe, đưa đón và các hỗ trợ khác giúp kỳ nghỉ của bạn thuận tiện và trọn vẹn hơn.
            </p>
          </div>
          <a href="/tien-ich" class="group/cta inline-flex items-center gap-2 text-primary hover:text-accent text-sm font-semibold tracking-[0.12em] uppercase border-b border-primary/40 hover:border-accent transition-all duration-300 pb-0.5 self-start mt-10">
            Khám phá dịch vụ
            <span class="transition-transform duration-200 group-hover/cta:translate-x-1">→</span>
          </a>
        </div>

        <!-- Right: Ăn uống / BBQ — image block (~58%) -->
        <a href="/tien-ich#an-uong" class="group lg:flex-1 relative overflow-hidden block" style="min-height:420px;">
          <div class="absolute inset-0 bg-[#c9bfb2]">
            <img src="/images/co-so/coso-1.jpg" alt="Ăn uống & BBQ tại Hải An"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
          </div>
        </a>

      </div>

      <!-- Row 2: Two image blocks left + Text block right -->
      <div class="flex flex-col lg:flex-row gap-5 fade-item">

        <!-- Left: 2 stacked/grid image blocks (~58%) -->
        <div class="lg:flex-1 grid grid-cols-2 gap-5">
          <div class="group overflow-hidden relative" style="min-height:300px;">
            <div class="absolute inset-0 bg-[#d4ccc4]">
              <img src="/images/gioi-thieu/IMG_975.jpg" alt="Hải An Hotel"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
          </div>
          <div class="group overflow-hidden relative" style="min-height:300px;">
            <div class="absolute inset-0 bg-[#c8c0b8]">
              <img src="/images/gioi-thieu/IMG_999.jpg" alt="Hải An Hotel"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
          </div>
        </div>

        <!-- Right: Ăn uống — text block (~42%) -->
        <div class="lg:w-[42%] bg-[#ede8df] flex flex-col justify-between p-10 md:p-14" style="min-height:300px;">
          <div>
            <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
              Ăn uống
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Khám phá Đà Lạt, Bảo Lộc và những mẹo du lịch hữu ích từ đội ngũ Hải An.
            </p>
          </div>
          <a href="/blog" class="group/cta inline-flex items-center gap-2 text-primary hover:text-accent text-sm font-semibold tracking-[0.12em] uppercase border-b border-primary/40 hover:border-accent transition-all duration-300 pb-0.5 self-start mt-10">
            Đọc thêm
            <span class="transition-transform duration-200 group-hover/cta:translate-x-1">→</span>
          </a>
        </div>

      </div>

      <!-- Row 3: Blog — text left + image right -->
      <div class="flex flex-col lg:flex-row gap-5 mt-5 fade-item">

        <!-- Left: text block (~42%) -->
        <div class="lg:w-[42%] bg-[#ede8df] flex flex-col justify-between p-10 md:p-14" style="min-height:380px;">
          <div>
            <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
              Blog
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Khám phá Đà Lạt, Bảo Lộc và những mẹo du lịch hữu ích từ đội ngũ Hải An.
            </p>
          </div>
          <a href="/blog" class="group/cta inline-flex items-center gap-2 text-primary hover:text-accent text-sm font-semibold tracking-[0.12em] uppercase border-b border-primary/40 hover:border-accent transition-all duration-300 pb-0.5 self-start mt-10">
            Đọc thêm
            <span class="transition-transform duration-200 group-hover/cta:translate-x-1">→</span>
          </a>
        </div>

        <!-- Right: image block (~58%) -->
        <a href="/blog" class="group lg:flex-1 relative overflow-hidden block" style="min-height:380px;">
          <div class="absolute inset-0 bg-[#c4bcb4]">
            <img src="/images/gioi-thieu/IMG_9993.JPG" alt="Blog & Cẩm nang"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- Gallery Section -->
  <section id="hinh-anh" class="bg-[#FDFAF7] py-16 md:py-24">
    <div class="mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">

      <!-- Heading -->
      <div class="mb-10 fade-item">
        <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-3">Hải An</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Khoảnh Khắc Tại Hải An
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3"></div>
        <p class="text-text-muted text-sm mt-3">Những kỷ niệm đáng nhớ của khách hàng</p>
      </div>

      <!-- Masonry carousel track -->
      <div class="relative">
        <button id="gallery-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 z-10 w-10 h-10 rounded-full bg-white border border-border shadow-sm flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200" aria-label="Ảnh trước">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button id="gallery-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 z-10 w-10 h-10 rounded-full bg-white border border-border shadow-sm flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200" aria-label="Ảnh tiếp">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      <div class="overflow-hidden">
        <div id="gallery-track" style="
          display: flex;
          flex-direction: column;
          flex-wrap: wrap;
          height: 540px;
          gap: 12px;
          width: max-content;
          transition: transform 500ms ease;
        ">
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:320px;">
            <img src="/images/gallery/gallery-1.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:208px;">
            <img src="/images/gallery/gallery-2.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:260px;">
            <img src="/images/gallery/gallery-3.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:268px;">
            <img src="/images/gallery/gallery-4.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:300px;">
            <img src="/images/gallery/gallery-5.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:228px;">
            <img src="/images/gallery/gallery-6.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:240px;">
            <img src="/images/gallery/gallery-7.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:288px;">
            <img src="/images/gallery/gallery-8.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:540px;">
            <img src="/images/gallery/gallery-9.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
        </div>
      </div>
      </div>

    </div>
  </section>

  <script>
    (function () {
      const track = document.getElementById('gallery-track') as HTMLElement | null;
      const prevBtn = document.getElementById('gallery-prev');
      const nextBtn = document.getElementById('gallery-next');
      if (!track || !prevBtn || !nextBtn) return;

      const STEP = 280 + 12; // slide width + gap
      let offset = 0;

      function maxOffset() {
        return track.scrollWidth - track.parentElement!.clientWidth;
      }

      prevBtn.addEventListener('click', () => {
        offset = Math.max(0, offset - STEP * 2);
        track.style.transform = `translateX(-${offset}px)`;
      });

      nextBtn.addEventListener('click', () => {
        offset = Math.min(maxOffset(), offset + STEP * 2);
        track.style.transform = `translateX(-${offset}px)`;
      });
    })();
  </script>

  <!-- Dark Contact Section -->
  <section id="lien-he" class="bg-primary py-20 md:py-28">
    <div class="fade-item mx-auto w-full text-center" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">
      <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-4">Liên Hệ</p>
      <h2 class="font-heading font-bold text-white text-3xl md:text-4xl mb-4">Sẵn Sàng Đồng Hành</h2>
      <div class="w-12 h-px bg-accent mx-auto mb-6"></div>
      <p class="text-white/60 text-sm leading-relaxed max-w-md mx-auto mb-10">
        Đội ngũ Hải An luôn sẵn sàng hỗ trợ đặt phòng, tư vấn lịch trình và mọi yêu cầu đặc biệt của bạn.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="#"
          aria-disabled="true"
          class="inline-flex items-center gap-2 bg-accent text-white text-xs font-semibold tracking-[0.15em] uppercase px-8 py-4 transition-colors duration-300 cursor-not-allowed opacity-75"
          onclick="return false;"
        >
          <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Gọi Ngay
        </a>
        <a
          href="#"
          aria-disabled="true"
          class="inline-flex items-center gap-2 border border-white/30 text-white text-xs font-semibold tracking-[0.15em] uppercase px-8 py-4 transition-colors duration-300 cursor-not-allowed opacity-75"
          onclick="return false;"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <StickyContactBar />
</Layout>
