---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import Section from '../components/Section.astro';
import PropertyCard from '../components/PropertyCard.astro';
import Footer from '../components/Footer.astro';
import StickyContactBar from '../components/StickyContactBar.astro';
---

<Layout title="Hải An Villa Hotel - Khách Sạn Gia Đình Sạch Sẽ Tại [Địa Chỉ]">
  <Header />

  <!-- Hero Image Carousel -->
  <HeroCarousel />

  <!-- Giới Thiệu -->
  <section id="gioi-thieu" class="bg-white">
    <Section maxWidth={true}>
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary mb-4 leading-tight">
            Chào Mừng Đến Với Hải An
          </h2>
          <div class="w-12 h-0.5 bg-accent mb-8"></div>
          <p class="text-text-muted text-lg leading-relaxed mb-5">
            Hải An là hệ thống khách sạn gia đình với tiêu chí sạch sẽ, ấm cúng và thân thiện.
            Chúng tôi mang đến không gian lưu trú thoải mái, dịch vụ chân thành và giá cả hợp lý —
            lý tưởng cho những chuyến nghỉ dưỡng tại Đà Lạt và Bảo Lộc.
          </p>
          <p class="text-text-muted text-lg leading-relaxed">
            Với đội ngũ nhân viên nhiệt tình, chúng tôi luôn sẵn sàng hỗ trợ để mỗi kỳ nghỉ của bạn
            trở thành những kỷ niệm đáng nhớ.
          </p>
        </div>

        <!-- Right: editorial peek gallery -->
        <div id="intro-gallery" class="relative overflow-hidden h-[440px] md:h-[520px]">
          <div class="absolute rounded-xl overflow-hidden" data-intro-slide="0" style="opacity:0;z-index:1;">
            <img src="/images/gioi-thieu/IMG_975.jpg" alt="Hải An Villa Hotel" class="absolute inset-0 w-full h-full object-cover" />
          </div>
          <div class="absolute rounded-xl overflow-hidden" data-intro-slide="1" style="opacity:0;z-index:1;">
            <img src="/images/gioi-thieu/IMG_999.jpg" alt="Hải An Villa Hotel" class="absolute inset-0 w-full h-full object-cover" />
          </div>
          <div class="absolute rounded-xl overflow-hidden" data-intro-slide="2" style="opacity:0;z-index:1;">
            <img src="/images/gioi-thieu/IMG_9993.JPG" alt="Hải An Villa Hotel" class="absolute inset-0 w-full h-full object-cover" />
          </div>
          <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/25 to-transparent pointer-events-none z-10" aria-hidden="true"></div>
          <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-20">
            <button data-intro-dot="0" class="h-1.5 rounded-full transition-all duration-300" aria-label="Ảnh 1"></button>
            <button data-intro-dot="1" class="h-1.5 rounded-full transition-all duration-300" aria-label="Ảnh 2"></button>
            <button data-intro-dot="2" class="h-1.5 rounded-full transition-all duration-300" aria-label="Ảnh 3"></button>
          </div>
        </div>

      </div>
    </Section>
  </section>

  <script>
    (function () {
      const gallery = document.getElementById('intro-gallery');
      if (!gallery) return;

      const slideEls = Array.from(gallery.querySelectorAll<HTMLElement>('[data-intro-slide]'));
      const dotEls   = Array.from(gallery.querySelectorAll<HTMLElement>('[data-intro-dot]'));

      const TOTAL = slideEls.length;
      const SIDE  = 0.13;
      const TRANS = 'left 650ms ease-in-out, width 650ms ease-in-out, height 650ms ease-in-out, top 650ms ease-in-out, opacity 650ms ease-in-out';

      let current = 0;
      let timer: ReturnType<typeof setInterval>;

      function applyLayout(animated: boolean) {
        const W     = gallery.offsetWidth;
        const isMob = window.innerWidth < 768;
        const sideW = isMob ? 0 : Math.round(W * SIDE);
        const mainW = W - sideW * 2;

        slideEls.forEach((el, i) => {
          el.style.transition = animated ? TRANS : 'none';
          const off = ((i - current) + TOTAL) % TOTAL;

          if (isMob) {
            Object.assign(el.style, {
              left: '0', top: '0', width: '100%', height: '100%',
              opacity: off === 0 ? '1' : '0',
              zIndex: off === 0 ? '8' : '1',
              boxShadow: 'none',
            });
          } else if (off === 0) {
            Object.assign(el.style, {
              left: sideW + 'px', top: '0',
              width: mainW + 'px', height: '100%',
              opacity: '1', zIndex: '8',
              boxShadow: '0 24px 64px rgba(0,0,0,0.22)',
            });
          } else if (off === 1) {
            Object.assign(el.style, {
              left: (sideW + mainW) + 'px', top: '7%',
              width: sideW + 'px', height: '86%',
              opacity: '0.6', zIndex: '5',
              boxShadow: 'none',
            });
          } else if (off === TOTAL - 1) {
            Object.assign(el.style, {
              left: '0', top: '7%',
              width: sideW + 'px', height: '86%',
              opacity: '0.6', zIndex: '5',
              boxShadow: 'none',
            });
          } else {
            const enterRight = off < Math.ceil(TOTAL / 2);
            Object.assign(el.style, {
              left: enterRight ? (W + sideW) + 'px' : (-sideW * 2) + 'px', top: '7%',
              width: sideW + 'px', height: '86%',
              opacity: '0', zIndex: '1',
              boxShadow: 'none',
            });
          }
        });

        dotEls.forEach((d, i) => {
          d.className = i === current
            ? 'h-1.5 rounded-full transition-all duration-300 w-6 bg-white'
            : 'h-1.5 rounded-full transition-all duration-300 w-3 bg-white/60 hover:bg-white/90';
        });
      }

      function goTo(idx: number) {
        current = ((idx % TOTAL) + TOTAL) % TOTAL;
        applyLayout(true);
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), 4000);
      }

      dotEls.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
      window.addEventListener('resize', () => applyLayout(false));

      applyLayout(false);
      requestAnimationFrame(() => requestAnimationFrame(() => applyLayout(true)));
      timer = setInterval(() => goTo(current + 1), 4000);
    })();
  </script>

  <!-- Properties Section -->
  <section id="co-so" class="bg-surface">
    <Section maxWidth={true}>
      <div class="mb-12">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Cơ Sở Lưu Trú
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3"></div>
        <p class="text-text-muted text-sm mt-3">Hệ thống lưu trú của Hải An tại Đà Lạt và Bảo Lộc</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <PropertyCard
          featured={true}
          name="Hải An Villa Đà Lạt"
          description="Khách sạn gia đình tại trung tâm Đà Lạt — phòng sạch sẽ, đội ngũ thân thiện, giá hợp lý."
          ctaText="Xem Phòng"
          ctaHref="/phong-nghi"
        />
        <PropertyCard
          featured={true}
          name="Hải An Hotel Bảo Lộc"
          description="Khách sạn gia đình tại Bảo Lộc — không gian yên tĩnh, sạch sẽ, giá cả phải chăng."
          ctaText="Liên Hệ"
          ctaHref="/lien-he"
        />
        <PropertyCard
          featured={true}
          name="Hải An Homestay Bảo Lộc"
          description="Homestay ấm cúng tại Bảo Lộc — trải nghiệm gần gũi, không gian xanh mát."
          ctaText="Liên Hệ"
          ctaHref="/lien-he"
        />
      </div>
    </Section>
  </section>

  <!-- Blog Section -->
  <section id="blog" class="bg-surface">
    <Section maxWidth={true}>
      <div class="mb-10">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Tin Tức & Cẩm Nang
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3"></div>
        <p class="text-text-muted text-sm mt-3">Khám phá Đà Lạt, Bảo Lộc và những mẹo du lịch hữu ích</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article class="group cursor-pointer">
          <div class="bg-gradient-to-br from-accent-soft to-border rounded-xl h-56 mb-4 overflow-hidden relative">
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-all duration-300 rounded-xl"></div>
          </div>
          <p class="text-xs text-slate uppercase tracking-wide mb-2">12 tháng 5, 2025</p>
          <h3 class="font-heading font-bold text-primary text-xl mb-2 group-hover:text-accent transition-colors duration-200 leading-snug">
            Top 5 điểm check-in đẹp nhất Đà Lạt 2025
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-3 line-clamp-2">
            Đà Lạt không chỉ nổi tiếng với những đồi thông mờ sương mà còn có vô số địa điểm sống ảo đang chờ bạn khám phá.
          </p>
          <a href="#" class="text-accent text-sm font-semibold hover:text-accent-dark transition-colors duration-200 inline-flex items-center gap-1">
            Đọc Thêm <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </article>
        <article class="group cursor-pointer">
          <div class="bg-gradient-to-br from-primary/10 to-primary/20 rounded-xl h-56 mb-4 overflow-hidden relative">
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-all duration-300 rounded-xl"></div>
          </div>
          <p class="text-xs text-slate uppercase tracking-wide mb-2">5 tháng 4, 2025</p>
          <h3 class="font-heading font-bold text-primary text-xl mb-2 group-hover:text-accent transition-colors duration-200 leading-snug">
            Kinh nghiệm du lịch Bảo Lộc cho người mới
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-3 line-clamp-2">
            Bảo Lộc — thành phố trà xanh bình yên giữa cao nguyên, điểm đến lý tưởng để thư giãn và tái tạo năng lượng.
          </p>
          <a href="#" class="text-accent text-sm font-semibold hover:text-accent-dark transition-colors duration-200 inline-flex items-center gap-1">
            Đọc Thêm <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </article>
        <article class="group cursor-pointer">
          <div class="bg-gradient-to-br from-accent/20 to-accent-soft rounded-xl h-56 mb-4 overflow-hidden relative">
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-all duration-300 rounded-xl"></div>
          </div>
          <p class="text-xs text-slate uppercase tracking-wide mb-2">20 tháng 3, 2025</p>
          <h3 class="font-heading font-bold text-primary text-xl mb-2 group-hover:text-accent transition-colors duration-200 leading-snug">
            Lịch trình 3 ngày 2 đêm Đà Lạt — Bảo Lộc
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-3 line-clamp-2">
            Hành trình khám phá trọn vẹn hai thành phố miền cao với chi phí tiết kiệm và những trải nghiệm đáng nhớ.
          </p>
          <a href="#" class="text-accent text-sm font-semibold hover:text-accent-dark transition-colors duration-200 inline-flex items-center gap-1">
            Đọc Thêm <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </article>
      </div>
    </Section>
  </section>

  <!-- Vị Trí Section -->
  <section id="vi-tri" class="bg-background">
    <Section maxWidth={true}>
      <div class="mb-10">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary">
          Vị Trí
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3"></div>
      </div>
      <div class="rounded-2xl overflow-hidden border border-border h-80 md:h-[480px] bg-accent-soft relative">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="opacity-20" aria-hidden="true">
            <svg class="w-20 h-20 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
        </div>
      </div>
    </Section>
  </section>

  <Footer />
  <StickyContactBar />
</Layout>
