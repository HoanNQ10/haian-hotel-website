---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import Section from '../components/Section.astro';
import IntroImageRail from '../components/IntroImageRail.astro';
import PropertyCard from '../components/PropertyCard.astro';
import Footer from '../components/Footer.astro';
import StickyContactBar from '../components/StickyContactBar.astro';
---

<Layout title="Hải An Villa Hotel - Khách Sạn Gia Đình Sạch Sẽ Tại [Địa Chỉ]">
  <Header />

  <!-- Hero Image Carousel -->
  <HeroCarousel />

  <!-- Giới Thiệu -->
  <section id="gioi-thieu" class="overflow-hidden bg-[#EFEFED]">
    <div class="mx-auto w-full" style="max-width: 1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">
      <div class="flex flex-col lg:flex-row lg:gap-12" style="min-height: clamp(500px, 52vw, 760px);">

        <!-- Left: text panel -->
        <div class="lg:w-[42%] flex flex-col justify-center py-14 lg:py-0">

          <!-- Heading -->
          <div class="mb-6 fade-item" style="transition-delay: 80ms;">
            <p class="font-heading font-bold text-primary/60 leading-none mb-3" style="font-size: 15px; letter-spacing: 0.18em;">WELCOME TO</p>
            <h2 class="font-heading font-bold text-primary leading-none" style="font-size: clamp(40px, 4.5vw, 64px);">
              HẢI AN HOTEL
            </h2>
          </div>

          <!-- Description -->
          <p class="text-text-muted leading-relaxed mb-6 fade-item" style="font-size: 14px; max-width: 400px; transition-delay: 160ms;">
            Hải An là hệ thống khách sạn gia đình với tiêu chí sạch sẽ, ấm cúng và thân thiện.
            Chúng tôi mang đến không gian lưu trú thoải mái, dịch vụ chân thành và giá cả hợp lý —
            lý tưởng cho những chuyến nghỉ dưỡng tại Đà Lạt và Bảo Lộc.
          </p>

          <!-- CTA -->
          <a
            href="#co-so"
            class="self-start inline-flex items-center gap-2 bg-primary hover:bg-primary/85 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 fade-item"
            style="transition-delay: 240ms;"
          >
            Khám Phá
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

        </div>

        <!-- Right: IntroImageRail -->
        <div class="lg:flex-1 flex items-center overflow-hidden">
          <IntroImageRail />
        </div>

      </div>
    </div>
  </section>

  <!-- Quote Divider -->
  <div class="bg-white py-14 md:py-20">
    <div class="mx-auto text-center" style="max-width: 800px; padding: 0 clamp(24px, 5vw, 80px);">
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px bg-accent"></div>
        <div class="w-1.5 h-1.5 bg-accent rotate-45 flex-shrink-0"></div>
        <div class="flex-1 h-px bg-accent"></div>
      </div>
      <p class="font-heading italic text-primary/75 leading-relaxed fade-item" style="font-size: clamp(17px, 1.8vw, 26px);">
        "Hải An — nơi mỗi chuyến nghỉ dưỡng trở thành kỷ niệm ấm áp,<br>và mỗi căn phòng là không gian bạn muốn quay lại."
      </p>
      <div class="flex items-center gap-4 mt-8">
        <div class="flex-1 h-px bg-accent"></div>
        <div class="w-1.5 h-1.5 bg-accent rotate-45 flex-shrink-0"></div>
        <div class="flex-1 h-px bg-accent"></div>
      </div>
    </div>
  </div>

  <!-- Properties Section -->
  <section id="co-so" class="relative overflow-hidden bg-[#EFEFED]">
    <div class="absolute left-0 right-0 bottom-0 bg-white" style="top: 410px;"></div>
    <div class="relative py-16 md:py-24 mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">

      <!-- Heading -->
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-primary leading-none fade-item" style="font-size: clamp(34px, 3.6vw, 52px);">Cơ Sở</h2>
      </div>

      <!-- 3 cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="fade-item" style="transition-delay: 0ms;">
          <PropertyCard
            name="Hải An Villa Đà Lạt"
            location="Đà Lạt, Lâm Đồng"
            description="Toạ lạc tại trung tâm thành phố, Hải An Villa Đà Lạt mang đến không gian lưu trú ấm cúng với phòng ngủ sạch sẽ, thiết kế gần gũi và đội ngũ phục vụ tận tình. Lý tưởng cho gia đình và cặp đôi muốn khám phá Đà Lạt theo nhịp riêng."
            ctaText="Xem Phòng"
            ctaHref="/phong-nghi"
            image="/images/co-so/coso-1.jpg"
          />
        </div>
        <div class="fade-item" style="transition-delay: 120ms;">
          <PropertyCard
            name="Hải An Hotel Bảo Lộc"
            location="Bảo Lộc, Lâm Đồng"
            description="Nằm giữa lòng Bảo Lộc yên bình, khách sạn có không gian thoáng đãng, phòng nghỉ sạch sẽ và bầu không khí trong lành. Thích hợp cho những ai muốn tạm rời nhịp sống hối hả và tìm về sự yên tĩnh."
            ctaText="Liên Hệ"
            ctaHref="/lien-he"
            image="/images/co-so/coso-2.jpg"
          />
        </div>
        <div class="fade-item" style="transition-delay: 240ms;">
          <PropertyCard
            name="Hải An Homestay Bảo Lộc"
            location="Bảo Lộc, Lâm Đồng"
            description="Trải nghiệm lưu trú gần gũi với thiên nhiên — vườn xanh mát, không khí trong lành và phong cách homestay ấm áp. Nơi lý tưởng để nghỉ ngơi, thư giãn và tận hưởng cuộc sống chậm giữa lòng Bảo Lộc."
            ctaText="Liên Hệ"
            ctaHref="/lien-he"
            image="/images/co-so/coso-3.jpg"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- Quote Divider 2 -->
  <div class="bg-[#EFEFED] py-14 md:py-20">
    <div class="mx-auto text-center" style="max-width: 800px; padding: 0 clamp(24px, 5vw, 80px);">
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px bg-accent"></div>
        <div class="w-1.5 h-1.5 bg-accent rotate-45 flex-shrink-0"></div>
        <div class="flex-1 h-px bg-accent"></div>
      </div>
      <p class="font-heading italic text-primary/75 leading-relaxed fade-item" style="font-size: clamp(17px, 1.8vw, 26px);">
        "Mỗi tiện ích tại Hải An được chăm chút tận tâm,<br>để kỳ nghỉ của bạn trọn vẹn từng khoảnh khắc."
      </p>
      <div class="flex items-center gap-4 mt-8">
        <div class="flex-1 h-px bg-accent"></div>
        <div class="w-1.5 h-1.5 bg-accent rotate-45 flex-shrink-0"></div>
        <div class="flex-1 h-px bg-accent"></div>
      </div>
    </div>
  </div>

  <!-- Editorial Hub Section -->
  <section id="kham-pha" class="relative overflow-hidden bg-white py-20 md:py-28">
    <div class="mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">

      <!-- Row 1: Text block left + Image block right -->
      <div class="flex flex-col lg:flex-row gap-5 mb-5 fade-item">

        <!-- Left: Dịch vụ & Tiện ích — text block (~42%) -->
        <div class="lg:w-[42%] flex flex-col py-12 pr-10 pl-0" style="min-height:420px;">
          <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
            Dịch vụ
          </h3>
          <p class="text-text-muted text-sm leading-relaxed mb-5">
            Từ dịch vụ spa thư giãn, thuê xe khám phá thành phố đến đưa đón sân bay — đội ngũ Hải An sẵn sàng hỗ trợ mọi nhu cầu trong suốt chuyến đi của bạn. Chúng tôi tin rằng một kỳ nghỉ trọn vẹn bắt đầu từ những tiện ích chu đáo.
          </p>
          <a href="/tien-ich" class="group/cta self-start inline-flex items-center gap-2 bg-primary hover:bg-primary/85 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 mt-5">
            Khám phá dịch vụ
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Right: Ăn uống / BBQ — image block (~58%) -->
        <a href="/tien-ich#an-uong" class="group lg:flex-1 relative overflow-hidden block" style="min-height:420px;">
          <div class="absolute inset-0 bg-[#C8C0A8]">
            <img src="/images/editorial/Spa.jpg" alt="Dịch vụ tại Hải An"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
          </div>
        </a>

      </div>

      <!-- Row 2: Two image blocks left + Text block right -->
      <div class="flex flex-col lg:flex-row gap-5 fade-item">

        <!-- Left: 2 stacked/grid image blocks (~58%) -->
        <div class="lg:flex-1 grid grid-cols-2 gap-5">
          <div class="group overflow-hidden relative" style="min-height:300px;">
            <div class="absolute inset-0 bg-[#C4BCA8]">
              <img src="/images/editorial/an-uong-1.jpg" alt="Ăn uống tại Hải An"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
          </div>
          <div class="group overflow-hidden relative" style="min-height:300px;">
            <div class="absolute inset-0 bg-[#C0B8A4]">
              <img src="/images/editorial/an-uong-2.jpg" alt="Ăn uống tại Hải An"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
          </div>
        </div>

        <!-- Right: Ăn uống — text block (~42%) -->
        <div class="lg:w-[42%] flex flex-col justify-between py-12 pl-10 pr-10" style="min-height:300px;">
          <div>
            <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
              Ăn uống
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Khám phá những quán cà phê view đẹp, nhà hàng địa phương và đặc sản vùng cao mà đội ngũ Hải An yêu thích. Chúng tôi chia sẻ những địa điểm ăn uống chân thực — không phải quảng cáo, chỉ là trải nghiệm thật.
            </p>
          </div>
          <a href="/blog" class="group/cta self-start inline-flex items-center gap-2 bg-primary hover:bg-primary/85 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 mt-5">
            Đọc thêm
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>

      <!-- Row 3: Blog — text left + image right -->
      <div class="flex flex-col lg:flex-row gap-5 mt-5 fade-item">

        <!-- Left: text block (~42%) -->
        <div class="lg:w-[42%] flex flex-col py-12 pr-10 pl-0" style="min-height:380px;">
          <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl leading-snug mb-5">
            Blog
          </h3>
          <p class="text-text-muted text-sm leading-relaxed mb-5">
            Cẩm nang du lịch Đà Lạt và Bảo Lộc từ góc nhìn người địa phương — những con đường ít người biết, mùa hoa đẹp nhất trong năm và mẹo di chuyển tiết kiệm. Hải An chia sẻ để chuyến đi của bạn thêm ý nghĩa.
          </p>
          <a href="/blog" class="group/cta self-start inline-flex items-center gap-2 bg-primary hover:bg-primary/85 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 mt-5">
            Đọc thêm
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Right: image block (~58%) -->
        <a href="/blog" class="group lg:flex-1 relative overflow-hidden block" style="min-height:380px;">
          <div class="absolute inset-0 bg-[#BCB4A0]">
            <img src="/images/editorial/blog.jpg" alt="Blog & Cẩm nang"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- Gallery Section -->
  <section id="hinh-anh" class="bg-white py-16 md:py-24">
    <div class="mx-auto w-full" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">

      <!-- Heading -->
      <div class="mb-10">
        <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-3 fade-item" style="transition-delay: 0ms;">Hải An</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary fade-item" style="transition-delay: 100ms;">
          Khoảnh Khắc Tại Hải An
        </h2>
        <div class="w-12 h-0.5 bg-accent mt-3 fade-item" style="transition-delay: 160ms;"></div>
        <p class="text-text-muted text-sm mt-3 fade-item" style="transition-delay: 220ms;">Những kỷ niệm đáng nhớ của khách hàng</p>
      </div>

      <!-- Masonry carousel track -->
      <div class="relative">
        <button id="gallery-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 z-10 w-10 h-10 rounded-full bg-white border border-border shadow-sm flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200" aria-label="Ảnh trước">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button id="gallery-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 z-10 w-10 h-10 rounded-full bg-white border border-border shadow-sm flex items-center justify-center text-text-muted hover:border-primary hover:text-primary transition-colors duration-200" aria-label="Ảnh tiếp">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      <div class="overflow-hidden">
        <div id="gallery-track" style="
          display: flex;
          flex-direction: column;
          flex-wrap: wrap;
          height: 540px;
          gap: 12px;
          width: max-content;
          transition: transform 500ms ease;
        ">
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:320px;">
            <img src="/images/gallery/gallery-1.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:208px;">
            <img src="/images/gallery/gallery-2.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:260px;">
            <img src="/images/gallery/gallery-3.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:268px;">
            <img src="/images/gallery/gallery-4.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:300px;">
            <img src="/images/gallery/gallery-5.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:228px;">
            <img src="/images/gallery/gallery-6.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:240px;">
            <img src="/images/gallery/gallery-7.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:288px;">
            <img src="/images/gallery/gallery-8.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="group overflow-hidden flex-shrink-0" style="width:280px; height:540px;">
            <img src="/images/gallery/gallery-9.jpg" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
        </div>
      </div>
      </div>

    </div>
  </section>

  <script>
    // Gallery carousel
    (function () {
      const track = document.getElementById('gallery-track') as HTMLElement | null;
      const prevBtn = document.getElementById('gallery-prev');
      const nextBtn = document.getElementById('gallery-next');
      if (!track || !prevBtn || !nextBtn) return;

      const STEP = 280 + 12; // slide width + gap
      let offset = 0;

      function maxOffset() {
        return track.scrollWidth - track.parentElement!.clientWidth;
      }

      prevBtn.addEventListener('click', () => {
        offset = Math.max(0, offset - STEP * 2);
        track.style.transform = `translateX(-${offset}px)`;
      });

      nextBtn.addEventListener('click', () => {
        offset = Math.min(maxOffset(), offset + STEP * 2);
        track.style.transform = `translateX(-${offset}px)`;
      });
    })();

  </script>

  <script is:inline>
    (function () {
      function initObserver() {
        var items = document.querySelectorAll('.fade-item');
        if (!items.length) return;
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            } else {
              entry.target.classList.remove('visible');
            }
          });
        }, { threshold: 0.1 });
        items.forEach(function (el) { observer.observe(el); });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initObserver);
      } else {
        initObserver();
      }
    })();
  </script>

  <!-- Dark Contact Section -->
  <section id="lien-he" class="bg-primary py-20 md:py-28">
    <div class="fade-item mx-auto w-full text-center" style="max-width:1440px; padding-left: clamp(12px, 2vw, 32px); padding-right: clamp(12px, 2vw, 32px);">
      <p class="text-xs tracking-[0.22em] uppercase text-accent font-medium mb-4">Liên Hệ</p>
      <h2 class="font-heading font-bold text-white text-3xl md:text-4xl mb-4">Sẵn Sàng Đồng Hành</h2>
      <div class="w-12 h-px bg-accent mx-auto mb-6"></div>
      <p class="text-white/60 text-sm leading-relaxed max-w-md mx-auto mb-10">
        Đội ngũ Hải An luôn sẵn sàng hỗ trợ đặt phòng, tư vấn lịch trình và mọi yêu cầu đặc biệt của bạn.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="#"
          aria-disabled="true"
          class="inline-flex items-center gap-2 bg-white hover:bg-white/90 text-primary text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 cursor-not-allowed opacity-75"
          onclick="return false;"
        >
          <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Gọi Ngay
        </a>
        <a
          href="#"
          aria-disabled="true"
          class="inline-flex items-center gap-2 border border-white/50 hover:border-white/80 text-white text-xs font-semibold tracking-[0.15em] uppercase px-5 py-3 transition-colors duration-300 cursor-not-allowed opacity-75"
          onclick="return false;"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <StickyContactBar />
</Layout>
