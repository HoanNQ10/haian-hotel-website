---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { rooms } from '../data/rooms';

const singleRooms = rooms.filter((r) => r.typeName.includes('Đơn'));
---

<Layout title="Phòng Đơn — Hải An Villa Hotel" description="Tất cả phòng đơn tại Hải An Villa Đà Lạt — 1 giường đơn, phù hợp cho 1–2 người.">
  <Header />

  {singleRooms.map((room, index) => (
    <section
      class={`${index % 2 === 0 ? 'bg-surface' : 'bg-background'}${index < singleRooms.length - 1 ? ' border-b border-border' : ''}`}
      aria-label={`Phòng ${room.number}`}
    >
      <div class="max-w-container mx-auto px-4 md:px-8 py-10">
        <div class="grid md:grid-cols-[3fr_2fr] gap-8 md:gap-28 items-start">

          <!-- Left: Gallery -->
          <div data-gallery>
            <div class="relative rounded-xl overflow-hidden aspect-[4/3] bg-border mb-3">
              {room.slides.map((slide, i) => (
                <div class={`gallery-slide absolute inset-0${i !== 0 ? ' hidden' : ''}`} data-index={i}>
                  {slide.type === 'gradient'
                    ? <div class={`w-full h-full ${slide.value}`}></div>
                    : <img src={slide.src} alt={slide.alt} class="w-full h-full object-cover" />
                  }
                </div>
              ))}
              <button
                class="gallery-prev absolute left-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-9 h-9 flex items-center justify-center shadow transition-all duration-200"
                aria-label="Ảnh trước"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>
              <button
                class="gallery-next absolute right-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-9 h-9 flex items-center justify-center shadow transition-all duration-200"
                aria-label="Ảnh tiếp"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
            </div>

            <div class="grid grid-cols-5 gap-1.5">
              {room.slides.map((slide, i) => (
                <button
                  class={`gallery-thumb rounded-lg overflow-hidden aspect-[4/3] ring-offset-1 transition-all duration-200${i === 0 ? ' ring-2 ring-accent' : ' ring-1 ring-border hover:ring-accent/50'}`}
                  aria-label={`Xem ảnh ${i + 1}`}
                >
                  {slide.type === 'gradient'
                    ? <div class={`w-full h-full ${slide.value}`}></div>
                    : <img src={slide.src} alt={`Ảnh ${i + 1}`} class="w-full h-full object-cover" />
                  }
                </button>
              ))}
            </div>
          </div>

          <!-- Right: Details -->
          <div class="pt-1">
            <h2 class="text-2xl font-heading font-bold text-primary mb-1">Phòng {room.number}</h2>
            <p class="text-sm text-text-muted mb-2">{room.typeName}</p>
            <div class="w-8 h-0.5 bg-accent mb-5"></div>
            <p class="text-text-muted text-sm leading-relaxed mb-6">{room.description}</p>

            <div class="divide-y divide-border text-sm">
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7h18M3 7v10h18V7M3 11h18"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Loại giường</span>
                <span class="text-primary font-medium">{room.bedType}</span>
              </div>
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Sức chứa</span>
                <span class="text-primary font-medium">{room.capacity}</span>
              </div>
              <div class="flex items-center gap-4 py-3">
                <svg class="w-5 h-5 flex-shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3M9 7h1m-1 4h1m4-4h1m-1 4h1"/>
                </svg>
                <span class="text-text-muted w-24 flex-shrink-0">Tầng</span>
                <span class="text-primary font-medium">{room.floor}</span>
              </div>
            </div>

            <div class="mt-8">
              <a
                href="/lien-he"
                class="inline-flex items-center justify-center border border-primary text-primary bg-transparent px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:bg-primary hover:text-white transition-all duration-200"
              >
                Liên Hệ Đặt Phòng
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>
  ))}

  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((container) => {
    const slides = container.querySelectorAll<HTMLElement>('.gallery-slide');
    const thumbs = container.querySelectorAll<HTMLElement>('.gallery-thumb');
    const prev = container.querySelector<HTMLElement>('.gallery-prev');
    const next = container.querySelector<HTMLElement>('.gallery-next');

    if (!slides.length || !thumbs.length) return;

    let current = 0;
    const total = slides.length;

    function goTo(n: number) {
      slides[current].classList.add('hidden');
      thumbs[current].classList.remove('ring-2', 'ring-accent');
      thumbs[current].classList.add('ring-1', 'ring-border');
      current = (n + total) % total;
      slides[current].classList.remove('hidden');
      thumbs[current].classList.remove('ring-1', 'ring-border');
      thumbs[current].classList.add('ring-2', 'ring-accent');
    }

    thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));
    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));
  });
</script>
